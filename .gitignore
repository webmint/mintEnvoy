# init_helper / configure_helper state files — framework-generated user
# state, NOT framework-shipped templates. install.sh copies the entire
# src/devforge/ tree to the target's .devforge/, so any stray here gets
# overwritten on the target's actual user state. KEEP THESE GITIGNORED.
src/devforge/init.yaml
src/devforge/configure.yaml
src/devforge/configure.yaml.lock
src/devforge/constitute.json
src/devforge/constitute.json.lock
src/devforge/.preflight-stamp
src/devforge/cbm-usage.log
