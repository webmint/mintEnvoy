{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "MintEnvoy design tokens, extracted verbatim from styles.css. W3C DTCG format. Light is the base; dark overrides only the tokens listed under color.dark. Method and status colors are theme-aware (separate light/dark values).",

  "color": {
    "$type": "color",
    "accent": {
      "base": {
        "$value": "#10b981",
        "$description": "Default accent (Mint). Runtime-swappable to 12 options — see accentOptions."
      },
      "soft": { "$value": "color-mix(in oklab, {color.accent.base} 14%, transparent)" },
      "hover": { "$value": "color-mix(in oklab, {color.accent.base} 88%, black)" }
    },
    "light": {
      "bg": { "$value": "#fbfaf9" },
      "bgSunken": { "$value": "#f4f3f1" },
      "bgElev": { "$value": "#ffffff" },
      "bgHover": { "$value": "#f0efed" },
      "bgActive": { "$value": "#e8e6e3" },
      "border": { "$value": "#e8e6e3" },
      "borderStrong": { "$value": "#d6d3d0" },
      "borderFaint": { "$value": "#f0efed" },
      "text": { "$value": "#18181b" },
      "textMuted": { "$value": "#6c6c75" },
      "textFaint": { "$value": "#6e6e77" },
      "textInverse": { "$value": "#ffffff" }
    },
    "dark": {
      "bg": { "$value": "#0c0c0d" },
      "bgSunken": { "$value": "#08080a" },
      "bgElev": { "$value": "#141416" },
      "bgHover": { "$value": "#1c1c1f" },
      "bgActive": { "$value": "#25252a" },
      "border": { "$value": "#25252a" },
      "borderStrong": { "$value": "#34343a" },
      "borderFaint": { "$value": "#1c1c1f" },
      "text": { "$value": "#f4f4f5" },
      "textMuted": { "$value": "#a1a1aa" },
      "textFaint": { "$value": "#71717a" },
      "textInverse": { "$value": "#0c0c0d" }
    },
    "method": {
      "$description": "HTTP method colors. Rendered via .method.{METHOD} and recolored per [data-mstyle] variant.",
      "get": { "light": { "$value": "#0ea5e9" }, "dark": { "$value": "#38bdf8" } },
      "post": { "light": { "$value": "#22c55e" }, "dark": { "$value": "#4ade80" } },
      "put": { "light": { "$value": "#f59e0b" }, "dark": { "$value": "#fbbf24" } },
      "patch": { "light": { "$value": "#a855f7" }, "dark": { "$value": "#c084fc" } },
      "delete": { "light": { "$value": "#ef4444" }, "dark": { "$value": "#f87171" } },
      "options": { "light": { "$value": "#64748b" }, "dark": { "$value": "#94a3b8" } }
    },
    "status": {
      "$description": "Response status-class colors. Theme-invariant in source.",
      "2xx": { "$value": "#16a34a" },
      "3xx": { "$value": "#2563eb" },
      "4xx": { "$value": "#f59e0b" },
      "5xx": { "$value": "#ef4444" }
    }
  },

  "accentOptions": {
    "$type": "color",
    "$description": "The 12 runtime-selectable accent values (Tweaks → Accent).",
    "mint": { "$value": "#10b981" },
    "cyan": { "$value": "#06b6d4" },
    "blue": { "$value": "#3b82f6" },
    "indigo": { "$value": "#6366f1" },
    "violet": { "$value": "#8b5cf6" },
    "pink": { "$value": "#ec4899" },
    "rose": { "$value": "#f43f5e" },
    "orange": { "$value": "#f97316" },
    "yellow": { "$value": "#eab308" },
    "lime": { "$value": "#84cc16" },
    "teal": { "$value": "#14b8a6" },
    "graphite": { "$value": "#a3a3a3" }
  },

  "radius": {
    "$type": "dimension",
    "sm": { "$value": "5px" },
    "md": { "$value": "9px" },
    "lg": { "$value": "12px" },
    "default": { "$value": "7px" }
  },

  "shadow": {
    "$type": "shadow",
    "$description": "Raw CSS strings (composite shadows). Light/dark differ.",
    "sm": {
      "light": { "$value": "0 1px 0 rgba(24,24,27,0.04), 0 1px 2px rgba(24,24,27,0.04)" },
      "dark": { "$value": "0 1px 0 rgba(0,0,0,0.4)" }
    },
    "md": {
      "light": { "$value": "0 4px 16px -4px rgba(24,24,27,0.08), 0 2px 4px rgba(24,24,27,0.04)" },
      "dark": { "$value": "0 4px 16px -4px rgba(0,0,0,0.4)" }
    },
    "lg": {
      "light": { "$value": "0 16px 32px -8px rgba(24,24,27,0.12), 0 4px 12px rgba(24,24,27,0.06)" },
      "dark": { "$value": "0 16px 32px -8px rgba(0,0,0,0.5)" }
    }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "sans": {
        "$value": [
          "-apple-system",
          "BlinkMacSystemFont",
          "Inter",
          "SF Pro Text",
          "system-ui",
          "sans-serif"
        ]
      },
      "mono": {
        "$value": ["JetBrains Mono", "SF Mono", "ui-monospace", "Menlo", "Consolas", "monospace"]
      }
    },
    "size": {
      "$type": "dimension",
      "$description": "NORMALIZATION: prototype hardcodes px with no token layer. These are the de-facto values; adopt as tokens, do not re-hardcode. Core UI text is 12.5px.",
      "xs": { "$value": "9px" },
      "sm": { "$value": "10.5px" },
      "base": { "$value": "12.5px" },
      "md": { "$value": "13px" },
      "lg": { "$value": "14px" }
    }
  },

  "methodStyle": {
    "$type": "other",
    "$description": "data-mstyle on <html> switches how .method renders. Default: soft.",
    "$value": ["soft", "chip", "outline", "dot", "bar", "text"]
  },

  "theme": {
    "$type": "other",
    "$description": "data-theme on <html>. Light is base, dark overrides color.dark.",
    "$value": ["light", "dark"]
  }
}
